# AI Sentinel - Configuration
# Please copy this file to .env and fill in the keys.

# Required: Gemini API Key for Summarization
GEMINI_API_KEY=your_gemini_api_key_here

# Required: Beehiiv API Details (for Newsletter Platform)
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=your_beehiiv_pub_id_here

# Optional: Resend API Details (for Direct Email)
RESEND_API_KEY=your_resend_api_key_here
RESEND_TO_EMAIL=your_test_email@example.com
